---
import Base from '../layouts/Base.astro';
import CACHED_FINDINGS from '../data/transcript-findings.json';
---

<Base
  title="Transcript Analysis"
  description="Interactive analysis of the full 6,805-line AI session transcript by five expert personas."
  noindex={false}
>
  <style>
    /* ── Page layout ── */
    .transcript-page {
      display: flex;
      flex-direction: column;
      height: calc(100vh - var(--header-height));
      overflow: hidden;
    }

    .page-toolbar {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.6rem 1rem;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-bg-alt);
      flex-wrap: wrap;
    }

    .page-toolbar h1 {
      font-size: 0.9rem;
      font-weight: 700;
      margin: 0;
      flex: 0 0 auto;
    }

    .persona-select {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 0.3rem 0.6rem;
      color: var(--color-text);
      outline: none;
      cursor: pointer;
    }

    .persona-select:focus { border-color: var(--color-accent); }

    .analyze-btn {
      background: var(--color-accent);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      padding: 0.35rem 1rem;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
      white-space: nowrap;
    }

    .analyze-btn:hover { background: var(--color-accent-hover); }
    .analyze-btn:disabled { opacity: 0.55; cursor: default; }

    .toolbar-status {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      font-family: var(--font-mono);
      flex: 1 1 auto;
    }

    /* ── Two-pane layout ── */
    .panes {
      flex: 1 1 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      overflow: hidden;
      min-height: 0;
    }

    @media (max-width: 768px) {
      .panes { grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; }
    }

    /* ── Transcript pane ── */
    .transcript-pane {
      overflow-y: auto;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      line-height: 1.6;
      border-right: 1px solid var(--color-border);
    }

    .transcript-pane pre {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .t-line {
      display: flex;
      padding: 0 0.5rem;
    }

    .t-line:hover { background: rgba(0,0,0,0.04); }
    .t-line.highlighted { background: rgba(251,191,36,0.22); border-left: 3px solid #f59e0b !important; }

    .t-lineno {
      flex: 0 0 3.8rem;
      text-align: right;
      padding-right: 0.75rem;
      color: var(--color-text-muted);
      user-select: none;
      opacity: 0.5;
    }

    .t-text { flex: 1 1 auto; }

    /* Phase banding */
    .phase-productive .t-lineno { border-left: 3px solid #4ade80; }
    .phase-drift      .t-lineno { border-left: 3px solid #fbbf24; }
    .phase-spiral     .t-lineno { border-left: 3px solid #f87171; }

    /* Collapsed run rows */
    .t-collapsed {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.2rem 0.5rem;
      cursor: pointer;
      color: var(--color-text-muted);
      font-size: 0.68rem;
      font-style: italic;
      user-select: none;
    }
    .t-collapsed:hover { background: rgba(0,0,0,0.06); color: var(--color-accent); }
    .t-collapsed-bar {
      flex: 0 0 3.8rem;
      text-align: right;
      padding-right: 0.75rem;
      font-style: normal;
    }

    /* ── Findings pane ── */
    .findings-pane {
      overflow-y: auto;
      padding: 1rem;
      background: var(--color-bg-alt);
    }

    .findings-pane h2 {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-muted);
      margin-bottom: 0.75rem;
    }

    .findings-empty {
      color: var(--color-text-muted);
      font-size: 0.82rem;
      text-align: center;
      padding: 2rem 0;
    }

    .finding-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 0.85rem;
      margin-bottom: 0.65rem;
      cursor: default;
      transition: border-color 0.12s, background 0.12s;
    }

    .finding-card:hover { border-color: var(--color-accent); background: var(--color-bg-alt); }
    .finding-card.active { border-color: #f59e0b; background: rgba(251,191,36,0.08); }

    .finding-header {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      margin-bottom: 0.4rem;
    }

    .severity-badge {
      flex: 0 0 auto;
      display: inline-block;
      padding: 0.1rem 0.45rem;
      border-radius: 3px;
      font-size: 0.66rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .sev-critical  { background: rgba(239,68,68,0.15); color: #ef4444; }
    .sev-warning   { background: rgba(251,191,36,0.15); color: #d97706; }
    .sev-highlight { background: rgba(102,126,234,0.15); color: #6366f1; }
    .sev-info      { background: rgba(107,114,128,0.15); color: #6b7280; }

    .finding-label {
      font-size: 0.8rem;
      font-weight: 600;
      line-height: 1.3;
    }

    .finding-lines {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--color-accent);
      margin-bottom: 0.3rem;
    }

    .finding-excerpt {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--color-text-muted);
      background: var(--color-bg-alt);
      border-left: 3px solid var(--color-border);
      padding: 0.25rem 0.5rem;
      margin-bottom: 0.35rem;
      border-radius: 2px;
    }

    .finding-analysis {
      font-size: 0.78rem;
      color: var(--color-text);
      line-height: 1.5;
    }

    .finding-viz-link {
      display: inline-block;
      margin-top: 0.4rem;
      font-size: 0.72rem;
      color: var(--color-accent);
      text-decoration: none;
      font-family: var(--font-mono);
    }

    .finding-viz-link:hover { text-decoration: underline; }

    .summary-box {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 0.9rem;
      margin-bottom: 1rem;
      font-size: 0.82rem;
      line-height: 1.6;
      color: var(--color-text);
    }

    .summary-box strong {
      display: block;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-muted);
      margin-bottom: 0.3rem;
    }

    .error-box {
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.25);
      border-radius: var(--radius);
      padding: 0.75rem;
      font-size: 0.82rem;
      color: #ef4444;
      margin-bottom: 0.75rem;
    }

    .loading-indicator {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1.5rem 0;
      justify-content: center;
      color: var(--color-text-muted);
      font-size: 0.82rem;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .spinner {
      width: 16px; height: 16px;
      border: 2px solid var(--color-border);
      border-top-color: var(--color-accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      flex: 0 0 auto;
    }

    /* Phase legend */
    .phase-legend {
      display: flex;
      gap: 0.75rem;
      font-size: 0.7rem;
      color: var(--color-text-muted);
      margin-left: auto;
      align-items: center;
    }

    .legend-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 0.25rem;
    }
  </style>

  <div class="transcript-page" id="transcript-page">
    <div class="page-toolbar">
      <h1>Transcript Analysis</h1>

      <select class="persona-select" id="persona-select">
        <option value="behavioral_psychologist">Behavioral Psychologist</option>
        <option value="software_architect">Software Architect</option>
        <option value="ai_researcher">AI Researcher</option>
        <option value="therapist">Therapist</option>
        <option value="statistician">Statistician</option>
      </select>

      <button class="analyze-btn" id="analyze-btn" disabled>Analyze</button>

      <span class="toolbar-status" id="toolbar-status">Loading transcript…</span>

      <div class="phase-legend">
        <span><span class="legend-dot" style="background:#4ade80"></span>Productive (1–3500)</span>
        <span><span class="legend-dot" style="background:#fbbf24"></span>Drift (3501–3636)</span>
        <span><span class="legend-dot" style="background:#f87171"></span>Spiral (3637–6805)</span>
      </div>
    </div>

    <div class="panes">
      <div class="transcript-pane" id="transcript-pane">
        <div class="loading-indicator"><div class="spinner"></div> Loading 6,805 lines…</div>
      </div>

      <div class="findings-pane" id="findings-pane">
        <h2>Findings</h2>
        <div class="findings-empty" id="findings-empty">
          Select a persona and click Analyze to run an expert analysis of the transcript.
        </div>
        <div id="findings-content" style="display:none"></div>
      </div>
    </div>
  </div>

  <script define:vars={{ CACHED_FINDINGS }}>
    // ── Phase boundaries (1-indexed) ──
    const PHASE_PRODUCTIVE_END = 3500;
    const PHASE_DRIFT_END = 3636;

    let transcriptLines = [];
    let currentHighlightedLines = [];

    // ── Collapse threshold: runs of N+ near-identical lines get folded ──
    const COLLAPSE_MIN = 4;

    function normLine(s) {
      // Normalise for comparison: lowercase, collapse whitespace, strip punctuation
      return s.trim().toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 60);
    }

    // Group consecutive lines into runs: [{start, end, text}]
    function buildRuns(lines) {
      const runs = [];
      let i = 0;
      while (i < lines.length) {
        const key = normLine(lines[i]);
        let j = i + 1;
        // Advance while same normalised key (or blank)
        while (j < lines.length && (normLine(lines[j]) === key || (key === '' && normLine(lines[j]) === ''))) j++;
        runs.push({ start: i, end: j - 1, text: lines[i], count: j - i });
        i = j;
      }
      return runs;
    }

    // ── Render a single line div ──
    function makeLineEl(lineNum, text) {
      const div = document.createElement('div');
      div.className = 't-line ' + getPhaseClass(lineNum);
      div.id = 'tl-' + lineNum;
      const numSpan = document.createElement('span');
      numSpan.className = 't-lineno';
      numSpan.textContent = lineNum;
      const textSpan = document.createElement('span');
      textSpan.className = 't-text';
      textSpan.textContent = text;
      div.appendChild(numSpan);
      div.appendChild(textSpan);
      return div;
    }

    // ── Render transcript pane with collapsed runs ──
    function renderTranscript(lines) {
      const pane = document.getElementById('transcript-pane');
      const fragment = document.createDocumentFragment();
      const runs = buildRuns(lines);

      runs.forEach(run => {
        if (run.count >= COLLAPSE_MIN) {
          // Show first line, then a collapsed row for the rest
          fragment.appendChild(makeLineEl(run.start + 1, run.text));

          const colDiv = document.createElement('div');
          colDiv.className = 't-collapsed';
          colDiv.dataset.runStart = run.start + 2;
          colDiv.dataset.runEnd = run.end + 1;
          colDiv.dataset.text = run.text;
          colDiv.innerHTML =
            '<span class="t-collapsed-bar">···</span>' +
            '<span>▶ ' + (run.count - 1) + ' more identical lines (' +
            (run.start + 2) + '–' + (run.end + 1) + ') — click to expand</span>';
          colDiv.addEventListener('click', function() {
            const s = parseInt(this.dataset.runStart);
            const e = parseInt(this.dataset.runEnd);
            const txt = this.dataset.text;
            const expandFrag = document.createDocumentFragment();
            for (let n = s; n <= e; n++) expandFrag.appendChild(makeLineEl(n, txt));
            this.replaceWith(expandFrag);
          });
          fragment.appendChild(colDiv);
        } else {
          for (let n = run.start; n <= run.end; n++) {
            fragment.appendChild(makeLineEl(n + 1, lines[n]));
          }
        }
      });

      pane.innerHTML = '';
      pane.appendChild(fragment);
    }

    function getPhaseClass(lineNum) {
      if (lineNum <= PHASE_PRODUCTIVE_END) return 'phase-productive';
      if (lineNum <= PHASE_DRIFT_END) return 'phase-drift';
      return 'phase-spiral';
    }

    // ── Clear all highlights ──
    function clearHighlights() {
      currentHighlightedLines.forEach(n => {
        const el = document.getElementById('tl-' + n);
        if (el) el.classList.remove('highlighted');
      });
      currentHighlightedLines = [];
    }

    // ── Scroll to and highlight a line range ──
    function highlightLines(lineStart, lineEnd) {
      clearHighlights();

      const end = Math.min(lineEnd ?? lineStart, transcriptLines.length);

      // Expand any collapsed runs that overlap the target range
      document.querySelectorAll('.t-collapsed').forEach(el => {
        const s = parseInt(el.dataset.runStart);
        const e = parseInt(el.dataset.runEnd);
        if (s <= end && e >= lineStart) el.click();
      });

      for (let n = lineStart; n <= end; n++) {
        const el = document.getElementById('tl-' + n);
        if (el) {
          el.classList.add('highlighted');
          currentHighlightedLines.push(n);
        }
      }

      // Scroll first highlighted line into view
      const firstEl = document.getElementById('tl-' + lineStart);
      if (firstEl) {
        firstEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    // ── Render findings ──
    function renderFindings(data) {
      const container = document.getElementById('findings-content');
      const empty = document.getElementById('findings-empty');

      empty.style.display = 'none';
      container.style.display = 'block';
      container.innerHTML = '';

      // Summary box
      if (data.summary) {
        const box = document.createElement('div');
        box.className = 'summary-box';
        box.innerHTML = '<strong>' + escHtml(data.persona || 'Analysis') + '</strong>' + escHtml(data.summary);
        container.appendChild(box);
      }

      // Finding cards
      (data.findings || []).forEach(finding => {
        const card = document.createElement('div');
        card.className = 'finding-card';

        const sev = (finding.severity || 'info').toLowerCase();
        const sevClass = ['critical','warning','highlight','info'].includes(sev) ? 'sev-' + sev : 'sev-info';

        card.innerHTML = [
          '<div class="finding-header">',
          '<span class="severity-badge ' + sevClass + '">' + escHtml(sev) + '</span>',
          '<span class="finding-label">' + escHtml(finding.label || '') + '</span>',
          '</div>',
          finding.line_start ? '<div class="finding-lines">Lines ' + finding.line_start + (finding.line_end && finding.line_end !== finding.line_start ? '–' + finding.line_end : '') + '</div>' : '',
          finding.excerpt ? '<div class="finding-excerpt">' + escHtml(finding.excerpt) + '</div>' : '',
          '<div class="finding-analysis">' + escHtml(finding.analysis || '') + '</div>',
          finding.viz_link ? '<a class="finding-viz-link" href="' + escHtml(finding.viz_link) + '">→ View visualization</a>' : '',
        ].join('');

        if (finding.line_start) {
          card.addEventListener('mouseenter', () => {
            // Clear active state from all cards
            container.querySelectorAll('.finding-card').forEach(c => c.classList.remove('active'));
            card.classList.add('active');
            highlightLines(finding.line_start, finding.line_end || finding.line_start);
          });
          card.addEventListener('mouseleave', () => {
            card.classList.remove('active');
            clearHighlights();
          });
        }

        container.appendChild(card);
      });
    }

    // ── Fetch transcript ──
    async function loadTranscript() {
      try {
        const res = await fetch('/transcript.md');
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const text = await res.text();
        transcriptLines = text.split('\n');
        renderTranscript(transcriptLines);
        document.getElementById('toolbar-status').textContent =
          transcriptLines.length.toLocaleString() + ' lines loaded';
        document.getElementById('analyze-btn').disabled = false;
      } catch (err) {
        document.getElementById('transcript-pane').innerHTML =
          '<div style="padding:2rem;color:var(--color-danger)">Failed to load transcript: ' + escHtml(String(err)) + '</div>';
        document.getElementById('toolbar-status').textContent = 'Load failed';
      }
    }

    // ── Analyze (uses pre-fetched cached results, fake 2s delay) ──
    async function runAnalysis() {
      const persona = document.getElementById('persona-select').value;
      const btn = document.getElementById('analyze-btn');
      const status = document.getElementById('toolbar-status');
      const container = document.getElementById('findings-content');
      const empty = document.getElementById('findings-empty');

      btn.disabled = true;
      status.textContent = 'Analyzing…';
      empty.style.display = 'none';
      container.style.display = 'block';
      container.innerHTML = '<div class="loading-indicator"><div class="spinner"></div> Running analysis via Codenoscopy…</div>';

      await new Promise(r => setTimeout(r, 2000));

      const data = CACHED_FINDINGS[persona];
      if (data) {
        renderFindings(data);
        status.textContent = (data.findings?.length || 0) + ' findings from ' + (data.persona || persona);
      } else {
        container.innerHTML = '<div class="error-box">No cached analysis for persona: ' + escHtml(persona) + '</div>';
        status.textContent = 'Error';
      }
      btn.disabled = false;
    }

    // ── Utility ──
    function escHtml(s) {
      return String(s)
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;');
    }

    // ── Init ──
    document.getElementById('analyze-btn').addEventListener('click', runAnalysis);
    loadTranscript();
  </script>
</Base>
